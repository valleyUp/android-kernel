From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: AVD Kernel Builder <build@avd.local>
Date: Sat, 27 Jun 2026 00:00:00 +0000
Subject: [PATCH] hook: include linux/bug.h before x86 text-patching.h

asm/text-patching.h uses BUG_ON() which requires linux/bug.h. Without it,
clang fails when building hook/x86_64/patch_memory.c in-tree.
---
 kernel/hook/patch_memory.h | 1 +
 1 file changed, 1 insertion(+)

diff --git a/kernel/hook/patch_memory.h b/kernel/hook/patch_memory.h
index b375e139..0469fe6c 100644
--- a/kernel/hook/patch_memory.h
+++ b/kernel/hook/patch_memory.h
@@ -18,6 +18,7 @@
 #include "asm/insn.h" // IWYU pragma: keep
 #endif
 #elif __x86_64__
+#include <linux/bug.h>
 #include "asm/text-patching.h" // IWYU pragma: keep
 #else
 #error "Unsupported arch"
-- 
