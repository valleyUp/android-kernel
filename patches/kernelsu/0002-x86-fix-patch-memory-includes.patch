From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: VPS Builder <build@vps.local>
Date: Thu, 25 Jun 2026 00:00:00 +0000
Subject: [PATCH] x86: fix patch_memory includes for AVD 6.1 build

x86_64 patch_memory.c must not include asm/text-patching.h without
linux/init.h or asm/cacheflush.h (which pulls mm.h and triggers
-Warray-bounds via signal.h). Page table walkers pgd_offset and friends
are provided by linux/pgtable.h, previously obtained transitively through
cacheflush.h -> mm.h. Include linux/pgtable.h explicitly instead.
---
 kernel/hook/patch_memory.h           | 2 --
 kernel/hook/x86_64/patch_memory.c    | 8 ++------
 kernel/hook/x86_64/syscall_hook.c    | 1 -
 3 files changed, 2 insertions(+), 9 deletions(-)

diff --git a/kernel/hook/patch_memory.h b/kernel/hook/patch_memory.h
index 0ab8eecd..0d12bf73 100644
--- a/kernel/hook/patch_memory.h
+++ b/kernel/hook/patch_memory.h
@@ -15,8 +15,6 @@
 #elif LINUX_VERSION_CODE >= KERNEL_VERSION(4, 0, 0)
 #include "asm/insn.h" // IWYU pragma: keep
 #endif
-#elif defined(__x86_64__)
-#include "asm/text-patching.h" // IWYU pragma: keep
 #else
 #if LINUX_VERSION_CODE >= KERNEL_VERSION(4, 0, 0)
 #include "asm/insn.h" // IWYU pragma: keep
diff --git a/kernel/hook/x86_64/patch_memory.c b/kernel/hook/x86_64/patch_memory.c
index ad3351f8..6016d95e 100644
--- a/kernel/hook/x86_64/patch_memory.c
+++ b/kernel/hook/x86_64/patch_memory.c
@@ -5,18 +5,14 @@
 
 #ifdef __x86_64__
 
-#include "asm/text-patching.h" // IWYU pragma: keep
-
-#include <linux/cache.h>
 #include "../patch_memory.h"
 #include "klog.h" // IWYU pragma: keep
 #include <linux/cpumask.h>
 #include <linux/gfp.h> // IWYU pragma: keep
 #include <linux/uaccess.h>
 #include <linux/stop_machine.h>
-#include <asm/cacheflush.h>
 
-#include <asm/pgtable.h>
+#include <linux/pgtable.h>
 #include <asm/page.h>
 
 #if LINUX_VERSION_CODE >= KERNEL_VERSION(3, 14, 0)
diff --git a/kernel/hook/x86_64/syscall_hook.c b/kernel/hook/x86_64/syscall_hook.c
index ab22c5fb..7cf3e434 100644
--- a/kernel/hook/x86_64/syscall_hook.c
+++ b/kernel/hook/x86_64/syscall_hook.c
@@ -4,7 +4,6 @@
 
 #include <linux/kallsyms.h>
 #include <linux/mutex.h>
-#include <asm/cacheflush.h>
 #include "infra/symbol_resolver.h"
 #include "../patch_memory.h"
 #include "arch.h"
-- 
2.45.0
