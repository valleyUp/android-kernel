# ReSukiSU Kernel Configuration Fragment
# Applied on top of gki_defconfig for AVD (goldfish) x86_64 builds
#
# Usage: merged with gki_defconfig + virtual_device fragments via merge_config.sh

CONFIG_KSU=y

# ReSukiSU defaults to the tracepoint hook on modern GKI kernels (5.10+).
# For legacy 5.4/android11 targets, add a branch-specific patch/config fragment
# under patches/common-android11-5.4/ instead of editing upstream files directly.
