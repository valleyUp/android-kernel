# Android Kernel Build - Git Ignore
# This repo tracks build scripts, patches, and docs only.
# Kernel source and prebuilts are managed by repo; build artifacts are ephemeral.

# ── Repo-managed source trees (synced by `repo sync`, not committed) ──
/common/
/common-modules/
/.repo/
/kernel/
/build/
/tools/
/prebuilts/
/prebuilts-master/
/external/

# ── Bazel symlinks (generated by Kleaf/Bazel at build time) ──
/WORKSPACE
/bazel-*

# ── Build output ──
/out/
/dist/
/avd-resukisu-deploy/
/avd-resukisu-deploy.tar.gz
/avd-sukisu-deploy/
/avd-sukisu-deploy.tar.gz

# ── Prebuilt manager APK (large binary, gitignored) ──
/*.apk

# ── KernelSU backup / temp dirs ──
/KernelSU-bak/

# ── Temporary input files ──
/proc-version.txt

# ── Build logs ──
*.log
build-*.log

# ── Editor / IDE ──
.idea/
.vscode/
.serena/
*.swp
*.swo
*~

# ── Python ──
__pycache__/
*.pyc

# ── OS ──
.DS_Store
Thumbs.db
